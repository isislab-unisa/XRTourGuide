# Path assoluto della directory community_server sulla macchina host
APP_DIR=/home/ater/progetti/XRTourGuide/community_server

# Directory locale sull'host dove salvare i backup
BACKUP_ROOT=/srv/backups/community_server

# Numero massimo di backup da mantenere
BACKUP_RETENTION=2

# Nome servizio MySQL nel docker-compose.yml
DB_SERVICE=db_cs

# Upload remoto con rclone
ENABLE_RCLONE_UPLOAD=true

# Remote rclone configurato sull'host
RCLONE_REMOTE=gdrive:xr_tour_guide_backups/community_server

# Se true, prova a installare rclone se assente
AUTO_INSTALL_RCLONE=true

# Orario cron giornaliero
CRON_HOUR=23
CRON_MINUTE=50

# Log
LOG_DIR=/var/log/community_server
