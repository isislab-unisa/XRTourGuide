# ─────────────────────────────────────────────
# Database MySQL Community Server
# ─────────────────────────────────────────────
CS_DB_NAME=community_server
CS_DB_USER=community_user
CS_DB_PASSWORD=change-me-community-db-password
CS_DB_HOST=db_cs
CS_DB_PORT=3306

# ─────────────────────────────────────────────
# JWT / Session
# Usare una stringa lunga e casuale
# ─────────────────────────────────────────────
JWT_SECRET=change-me-long-random-jwt-secret

# ─────────────────────────────────────────────
# Default admin creato al primo avvio
# Cambiare subito la password dopo il primo login
# ─────────────────────────────────────────────
DEFAULT_USER_NAME=admin
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=change-me-admin-password

# ─────────────────────────────────────────────
# Email SMTP
# ─────────────────────────────────────────────
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=change-me-email-app-password

# URL pubblico del community server.
# Serve per link email verifica/reset.
# Se passa da Nginx:
# ─────────────────────────────────────────────
BASE_URL=https://community.example.com/communityserver

# ─────────────────────────────────────────────
# Google login mobile/web
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_ID_TOKEN_CLOCK_SKEW_SECONDS=60

# ─────────────────────────────────────────────
# Apple login
# Valori separati da virgola se ne hai più di uno
# ─────────────────────────────────────────────
APPLE_CLIENT_IDS=com.picaresque.xrtourguide

# ─────────────────────────────────────────────
# Registrazione app mobile autorizzata
# Usato da register_app.py / service mobile
# ─────────────────────────────────────────────
TEST_BUNDLE_ID=com.picaresque.xrtourguide
