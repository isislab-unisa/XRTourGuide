# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
SECRET_KEY=change-me-generate-a-long-random-secret
SITE_ID=1
FORCE_SCRIPT_NAME=/
DOMAIN=https://xrtourguide.example.com
CSRF_TRUSTED_ORIGIN=https://xrtourguide.example.com

# ─────────────────────────────────────────────
# Database MySQL Django
# ─────────────────────────────────────────────
DB_NAME=xr_tour_guide
DB_USER=xr_user
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=3306

# ─────────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
BUILD_TIMEOUT_MINUTES=30

# ─────────────────────────────────────────────
# MinIO / S3 storage
# ─────────────────────────────────────────────
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
AWS_STORAGE_BUCKET_NAME=xrtourguide
AWS_S3_ENDPOINT_URL=http://minio:9000

# ─────────────────────────────────────────────
# Community server / Identity provider
# Se il community server è nello stesso Docker network:
# COMMUNITY_SERVER_URL=http://community-server:8002
#
# Se è su un'altra macchina dietro Nginx:
# COMMUNITY_SERVER_URL=https://community.example.com/communityserver
# ─────────────────────────────────────────────
COMMUNITY_SERVER_URL=https://community.example.com/communityserver
IDP_API_KEY=change-me-service-api-key
IDP_API_SECRET=change-me-service-api-secret

# ─────────────────────────────────────────────
# AI services interni
# ─────────────────────────────────────────────
TRAIN_ENDPOINT=http://ai_training:8090/train
INFERENCE_ENDPOINT=http://ai_inference:8050/inference
INFERENCE_CACHE_CLEAR_ENDPOINT=http://ai_inference:8050/cache/clear

# Se usi PMTiles service
PMTILES_URL=http://pmtiles-server:8081

# ─────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=change-me-email-app-password

# ─────────────────────────────────────────────
# OAuth / frontend web
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret

# ─────────────────────────────────────────────
# Mobile app stores / deep links
# ─────────────────────────────────────────────
ANDROID_STORE=https://play.google.com/store/apps/details?id=com.picaresque.xrtourguide
IOS_STORE=https://apps.apple.com/app/id0000000000
