# Directory progetto, relativa alla macchina remota
APP_DIR=/home/ater/progetti/XRTourGuide/xr_tour_guide

# Dove salvare i backup locali sull'host
BACKUP_ROOT=/srv/backups/xr_tour_guide

# Numero massimo di backup da mantenere
BACKUP_RETENTION=2

# Docker network usato da MinIO
DOCKER_NETWORK=backend_net

# Remote rclone già configurato sulla macchina host
# Esempio: gdrive:xr_tour_guide_backups
RCLONE_REMOTE=gdrive:xr_tour_guide_backups

AUTO_INSTALL_RCLONE=true

# Se true, carica i backup anche su Google Drive tramite rclone
ENABLE_RCLONE_UPLOAD=true

# Ora del backup cron
CRON_HOUR=23
CRON_MINUTE=55

LOG_DIR=/var/log/xr_tour_guide
